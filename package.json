{
  "name": "foco",
  "private": true,
  "workspaces": [
    "web"
  ],
  "scripts": {
    "backend": "node scripts/dev-backend.mjs",
    "frontend": "node scripts/dev-frontend.mjs",
    "test": "cargo test --workspace && npm run test -w web && npm run typecheck -w web",
    "test:backend": "cargo test --workspace -j 4 -- --test-threads=4",
    "test:backend:calm": "cargo test --workspace -j 2 -- --test-threads=2",
    "test:release-smoke:windows": "node scripts/smoke-release-windows.mjs",
    "typecheck": "npm run typecheck -w web",
    "build:release": "node scripts/build-release.mjs",
    "build:dist": "node scripts/build-release.mjs --dist"
  }
}
